{
  "buildCommand": "cd artifacts/mockup-sandbox && npm run build",
  "outputDirectory": "artifacts/mockup-sandbox/dist",
  "installCommand": "pnpm install",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
