{
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "runtime": "nodejs18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/dist/index.mjs"
    },
    {
      "source": "/mockup/(.*)",
      "destination": "/artifacts/mockup-sandbox/$1"
    },
    {
      "source": "/restaurant/(.*)",
      "destination": "/artifacts/saiemaas-restaurant/dist/public/$1"
    },
    {
      "source": "/((?!api|mockup|restaurant).*)",
      "destination": "/artifacts/mockup-sandbox/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "3000",
    "BASE_PATH": "/"
  }
}
